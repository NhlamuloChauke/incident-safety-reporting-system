# Copy this file to .env and fill in values before running docker-compose

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=safemine
DB_USERNAME=safemine
DB_PASSWORD=safemine

# ── JWT — change this to a strong random string in production ─────────────────
JWT_SECRET=SafeMineDockerSecretKeyPleaseChangeInProduction!

# ── CORS — set to your frontend domain in production ─────────────────────────
CORS_ORIGINS=http://localhost

# ── Mail (optional) ───────────────────────────────────────────────────────────
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=
